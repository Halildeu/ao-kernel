+    Tool calls go through: authorize → handler → result.
+    """
+    from ao_kernel.tool_gateway import ToolGateway, ToolCallPolicy
+
+    gateway = ToolGateway(policy=ToolCallPolicy(enabled=True, max_rounds=50))
+
