{
  "version": "v1",
  "kind": "authority-matrix",
  "project_id": "PRJ-MULTI-AI-CODING-OS",
  "status": "INITIAL_POPULATION",
  "precedence_order": [
    "canonical",
    "execution_mirror",
    "current_delivery",
    "transition_active",
    "archive_reference",
    "workspace_derived"
  ],
  "layers": [
    {
      "layer_id": "canonical",
      "conflict_precedence": 1,
      "allowed_write_mode": "governed",
      "notes": [
        "Normatif kaynaklar",
        "Conflict aninda her zaman kazanir"
      ]
    },
    {
      "layer_id": "execution_mirror",
      "conflict_precedence": 2,
      "allowed_write_mode": "delivery_mirror",
      "notes": [
        "Execution tercihleri ve tenant kararlari icin gecici ama current mirror katmani",
        "Canonical ile celisemez"
      ]
    },
    {
      "layer_id": "current_delivery",
      "conflict_precedence": 3,
      "allowed_write_mode": "delivery",
      "notes": [
        "Guncel delivery gercegi",
        "Governance authority degil, execution context"
      ]
    },
    {
      "layer_id": "transition_active",
      "conflict_precedence": 4,
      "allowed_write_mode": "redirect_only",
      "notes": [
        "Rehber ve uyumluluk katmani",
        "Yeni normatif kural yazilmaz"
      ]
    },
    {
      "layer_id": "archive_reference",
      "conflict_precedence": 5,
      "allowed_write_mode": "blocked",
      "notes": [
        "Read-only archive",
        "Hicbir durumda live authority degil"
      ]
    },
    {
      "layer_id": "workspace_derived",
      "conflict_precedence": 6,
      "allowed_write_mode": "workspace_only",
      "notes": [
        "Derived planning, reports ve promotion adayi truth",
        "Canonical veya current delivery authority yerine gecmez"
      ]
    }
  ],
  "conflict_rules": [
    {
      "rule_id": "R1",
      "when": "canonical_vs_any",
      "winner_layer": "canonical",
      "notes": [
        "SSOT ve standards.lock ekseni son karari verir"
      ]
    },
    {
      "rule_id": "R2",
      "when": "execution_mirror_vs_current_delivery",
      "winner_layer": "execution_mirror",
      "notes": [
        "Tenant decision bundle ve execution mirror, current delivery baglamini sinirlar"
      ]
    },
    {
      "rule_id": "R3",
      "when": "transition_active_vs_archive_reference",
      "winner_layer": "transition_active",
      "notes": [
        "Redirect rehberler archive alanindan once gelir ama authority sayilmaz"
      ]
    },
    {
      "rule_id": "R4",
      "when": "workspace_derived_vs_any_authority_layer",
      "winner_layer": "authoritative_layer",
      "notes": [
        "Workspace-derived artefact yalniz planning ve evidence icindir"
      ]
    }
  ],
  "surfaces": [
    {
      "surface_id": "core:ssot-roadmap",
      "concern": "roadmap",
      "layer_id": "canonical",
      "repo_scope": "ao-core",
      "owner": "CORE",
      "authority_state": "canonical",
      "effective_paths": [
        "__WORKSPACE_ROOT__/roadmaps/SSOT/roadmap.v1.json"
      ],
      "supporting_paths": [
        "__WORKSPACE_ROOT__/docs/ROADMAP.md"
      ],
      "archive_paths": [
        "__WORKSPACE_ROOT__/docs/ROADMAP_v2.7_legacy.md"
      ],
      "write_policy": "governed_core_only",
      "notes": [
        "Machine truth JSON dosyasidir",
        "Markdown yalniz human mirror'dur"
      ]
    },
    {
      "surface_id": "core:governance-policies-and-schemas",
      "concern": "core_governance",
      "layer_id": "canonical",
      "repo_scope": "ao-core",
      "owner": "CORE",
      "authority_state": "canonical",
      "effective_paths": [
        "__WORKSPACE_ROOT__/standards.lock",
        "__WORKSPACE_ROOT__/docs/OPERATIONS/AI-MULTIREPO-OPERATING-CONTRACT.v1.md",
        "__WORKSPACE_ROOT__/docs/OPERATIONS/SSOT-MAP.md",
        "__WORKSPACE_ROOT__/docs/OPERATIONS/EXTENSIONS.md",
        "__WORKSPACE_ROOT__/policies/*.v1.json",
        "__WORKSPACE_ROOT__/schemas/*.json"
      ],
      "supporting_paths": [
        "__WORKSPACE_ROOT__/AGENTS.md"
      ],
      "archive_paths": [
        "__WORKSPACE_ROOT__/registry/archives/legacy_standards_archive.aistd.v1.json"
      ],
      "write_policy": "governed_core_only",
      "notes": [
        "Core governance her zaman source policy ve schema katmanindan okunur",
        "AGENTS yonlendiricidir ama policy yerine gecmez"
      ]
    },
    {
      "surface_id": "core:runtime-policy-overlays",
      "concern": "runtime_overlays",
      "layer_id": "workspace_derived",
      "repo_scope": "ao-core",
      "owner": "WORKSPACE",
      "authority_state": "derived_overlay",
      "effective_paths": [
        "__WORKSPACE_ROOT__/.cache/ws_customer_default/policies/policy_llm_providers_guardrails.v1.json"
      ],
      "supporting_paths": [
        "__WORKSPACE_ROOT__/policies/policy_llm_providers_guardrails.v1.json"
      ],
      "archive_paths": [],
      "write_policy": "derived_only",
      "notes": [
        "Workspace overlay source policy ile conflict halinde authority kazanmaz",
        "Drift tespiti yapilsa da normatif kabul edilmez"
      ]
    },
    {
      "surface_id": "managed:opo-governance",
      "concern": "managed_repo_opo",
      "layer_id": "canonical",
      "repo_scope": "dev",
      "owner": "EXECUTION",
      "authority_state": "canonical_for_managed_repo",
      "effective_paths": [
        "__HOME__/Documents/dev/standards.lock",
        "__HOME__/Documents/dev/docs/OPERATIONS/AI-MULTIREPO-OPERATING-CONTRACT.v1.md",
        "__HOME__/Documents/dev/docs/OPERATIONS/OPO-AUTHORITY-MAP.v1.md",
        "__HOME__/Documents/dev/docs/OPERATIONS/ARCHITECTURE-CONSTRAINTS.md",
        "__HOME__/Documents/dev/docs/OPERATIONS/CACHE-BOUNDARY-RULES.v1.md",
        "__HOME__/Documents/dev/docs/OPERATIONS/CODING-STANDARDS.md"
      ],
      "supporting_paths": [],
