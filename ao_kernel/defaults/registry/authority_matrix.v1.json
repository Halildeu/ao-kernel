      "effective_paths": [
        "__WORKSPACE_ROOT__/.cache/ws_customer_default/project/PRJ-MULTI-AI-CODING-OS/ai_entry_pack.v1.json",
        "__WORKSPACE_ROOT__/.cache/ws_customer_default/project/PRJ-MULTI-AI-CODING-OS/current_truth_snapshot.v1.md"
