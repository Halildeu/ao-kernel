    },
    {
      "surface_id": "managed:current-delivery",
      "concern": "delivery_truth",
      "layer_id": "current_delivery",
      "repo_scope": "dev",
      "owner": "EXECUTION",
      "authority_state": "current_delivery",
      "effective_paths": [
        "__HOME__/Documents/dev/docs/03-delivery/PROJECT-FLOW.md",
        "__HOME__/Documents/dev/docs/03-delivery/STORIES/**",
        "__HOME__/Documents/dev/docs/03-delivery/ACCEPTANCE/**",
        "__HOME__/Documents/dev/docs/04-operations/RUNBOOKS/**",
        "__HOME__/Documents/dev/extensions/PRJ-PM-SUITE/contract/feature_execution_contract.v1.json"
      ],
      "supporting_paths": [
