{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao-kernel.local/schemas/gp5-operations-support-package.schema.v1.json",
  "title": "GP-5.8 operations and support package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "program_id",
    "issue",
    "overall_status",
    "decision",
    "support_widening",
    "production_platform_claim",
    "runbook_coverage",
    "known_bugs",
    "support_boundary",
    "branch_protection",
    "promotion_decision"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "artifact_kind": { "const": "gp5_operations_support_package" },
    "program_id": { "const": "GP-5.8" },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "url"],
      "properties": {
        "number": { "const": 453 },
        "url": { "type": "string", "minLength": 1 }
      }
    },
    "overall_status": { "enum": ["ready", "blocked"] },
    "decision": {
      "enum": [
        "operations_package_ready_no_support_widening",
        "operations_package_blocked_no_support_widening"
      ]
    },
    "support_widening": { "const": false },
    "production_platform_claim": { "const": false },
    "blocked_reason": { "type": "string", "minLength": 1 },
    "runbook_coverage": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/coverage_item" }
    },
    "known_bugs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_path",
        "stable_shipped_baseline_blockers",
        "open_beta_lane_bugs",
        "promotion_blockers",
        "findings"
      ],
      "properties": {
        "registry_path": { "type": "string", "minLength": 1 },
        "stable_shipped_baseline_blockers": { "const": 0 },
        "open_beta_lane_bugs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "promotion_blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "findings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "support_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_boundary_unchanged",
        "promoted_tiers",
        "next_possible_claim_gate",
        "findings"
      ],
      "properties": {
        "stable_boundary_unchanged": { "const": true },
        "promoted_tiers": {
          "type": "array",
          "maxItems": 0,
          "items": { "type": "string" }
        },
        "next_possible_claim_gate": { "const": "GP-5.9" },
        "findings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "branch_protection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_checks_reviewed",
        "release_gate_impact",
        "findings"
      ],
      "properties": {
        "required_checks_reviewed": { "type": "boolean" },
        "release_gate_impact": { "const": "none" },
        "findings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "promotion_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_widening_allowed",
        "production_claim_allowed",
        "next_gate",
        "reason"
      ],
      "properties": {
        "support_widening_allowed": { "const": false },
        "production_claim_allowed": { "const": false },
        "next_gate": { "const": "GP-5.9" },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "overall_status": { "const": "blocked" } } },
      "then": { "required": ["blocked_reason"] }
    }
  ],
  "$defs": {
    "coverage_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "status", "source_path", "required_tokens", "findings"],
      "properties": {
        "surface": {
          "enum": [
            "adapter",
            "repo_intelligence",
            "vector_backend",
            "write_side",
            "pr_rollback",
            "packaging_release",
            "gp57b_aggregation",
            "known_bugs",
            "support_boundary",
            "branch_protection"
          ]
        },
        "status": { "enum": ["ready", "blocked"] },
        "source_path": { "type": "string", "minLength": 1 },
        "required_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "findings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
