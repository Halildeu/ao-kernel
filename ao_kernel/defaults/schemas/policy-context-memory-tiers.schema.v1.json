{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ao:policy-context-memory-tiers:v1",
  "title": "Context Memory Tiers Policy",
  "description": "Policy for HOT/WARM/COLD rule tier classification, autonomous evolution thresholds, and semantic retrieval backend configuration.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "tiers", "auto_evolution"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "description": { "type": "string" },
    "tiers": {
      "type": "object",
      "required": ["hot", "warm", "cold"],
      "additionalProperties": false,
      "properties": {
        "hot": { "type": "object", "required": ["always_load", "max_rules", "min_effectiveness"] },
        "warm": { "type": "object", "required": ["load_on_match", "max_rules", "min_effectiveness"] },
        "cold": { "type": "object", "required": ["load_on_demand", "archive_after_sessions"] }
      }
    },
    "auto_evolution": {
      "type": "object",
      "required": ["enabled", "auto_apply_threshold", "auto_apply_with_rollback_threshold", "manual_review_below"],
      "properties": {
        "enabled": { "type": "boolean" },
        "auto_apply_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "auto_apply_with_rollback_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "manual_review_below": { "type": "number", "minimum": 0, "maximum": 1 },
        "dead_session_threshold": { "type": "integer", "minimum": 1 }
      }
    },
    "semantic_retrieval": {
      "type": "object",
      "description": "Semantic retrieval feature gate. Backend instance is resolved via env/constructor; this policy controls enablement, fail-closed behavior, and embedding provider/model (independent of chat route).",
      "additionalProperties": false,
      "required": ["enabled", "backend"],
      "properties": {
        "enabled": { "type": "boolean" },
        "backend": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "strict", "fail_action"],
          "properties": {
            "type": { "type": "string", "enum": ["inmemory", "pgvector", "disabled"] },
            "strict": { "type": "boolean" },
            "fail_action": { "type": "string", "enum": ["raise", "warn_fallback"] }
          }
        },
        "embedding": {
          "type": "object",
          "description": "Embedding provider/model used for vector generation. Decoupled from chat route because most chat providers (Anthropic, DeepSeek, xAI) do not expose an embeddings endpoint.",
          "additionalProperties": false,
          "required": ["provider", "model"],
          "properties": {
            "provider": { "type": "string", "enum": ["openai", "google"] },
            "model": { "type": "string", "minLength": 1 },
            "base_url": { "type": "string", "format": "uri" }
          }
        }
      }
    }
  }
}
