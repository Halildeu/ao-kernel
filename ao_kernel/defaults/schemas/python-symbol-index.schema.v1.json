{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ao:python-symbol-index:v1",
  "title": "Python Symbol Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "generator",
    "project",
    "summary",
    "modules",
    "symbols",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "artifact_kind": {
      "const": "python_symbol_index"
    },
    "generator": {
      "$ref": "#/$defs/generator"
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python_modules", "symbols", "diagnostics"],
      "properties": {
        "python_modules": {
          "type": "integer",
          "minimum": 0
        },
        "symbols": {
          "type": "integer",
          "minimum": 0
        },
        "diagnostics": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/module_record"
      }
    },
    "symbols": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbol_record"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "generated_at"],
      "properties": {
        "name": {
          "const": "ao-kernel"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "root_name", "name", "root_identity_sha256"],
      "properties": {
        "root": {
          "const": "."
        },
        "root_name": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "root_identity_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "module_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "module", "path", "symbols"],
      "properties": {
        "kind": {
          "enum": ["package", "module"]
        },
        "module": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "symbols": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "symbol_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "module", "path", "name", "qualified_name", "lineno"],
      "properties": {
        "kind": {
          "enum": ["class", "function", "async_function", "assignment", "imported_name"]
        },
        "module": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "qualified_name": {
          "type": "string",
          "minLength": 1
        },
        "lineno": {
          "type": "integer",
          "minimum": 0
        },
        "alias_of": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "code", "message"],
      "properties": {
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string"
        },
        "lineno": {
          "type": "integer",
          "minimum": 1
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^/"
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
