{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "llm_resolver_rules",
  "type": "object",
  "required": ["policy_version", "intent_to_class", "fallback_order_by_class", "ttl_hours_default"],
  "properties": {
    "policy_version": { "type": "string" },
    "intent_to_class": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "fallback_order_by_class": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "strictness": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "verified_only": { "type": "boolean" },
          "degrade_allowed": { "type": "boolean" },
          "apply_fail_closed": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "soft_degrade": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from_class", "to_class", "intents"],
            "properties": {
              "from_class": { "type": "string" },
              "to_class": { "type": "string" },
              "intents": {
                "type": "array",
                "items": { "type": "string" }
              },
              "budget_remaining_threshold_usd": {
                "type": "number",
                "minimum": 0,
                "description": "PR-C4.1 additive: when present, rule is a budget-aware downgrade trigger — evaluated only when caller supplies budget_remaining AND remaining < threshold (STRICT less-than). Absent → rule is inert in C4.1 runtime (preserves pre-v3.3.1 dormant behavior for the bundled cost-agnostic rules)."
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "ttl_hours_default": { "type": "integer" },
    "ttl_hours_by_class": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "override_policy": {
      "type": "object",
      "properties": {
        "class_override_allowed": { "type": "boolean" },
        "provider_priority_allowed": { "type": "boolean" },
        "degrade_override_allowed": { "type": "boolean" },
        "audit_fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
