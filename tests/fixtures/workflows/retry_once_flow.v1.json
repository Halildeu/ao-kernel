{
  "$schema": "urn:ao:workflow-definition:v1",
  "workflow_id": "retry_once_flow",
  "workflow_version": "1.0.0",
  "display_name": "Retry Once Flow",
  "description": "Two-step flow where step1 has on_failure=retry_once (A4b test fixture).",
  "steps": [
